# ── NeuroLearn Backend ──

# Server
PORT=5000

# Groq (used for logical, auditory, visual styles)
# Get key from: https://console.groq.com/
GROQ_API_KEY= gsk_your_key_here

# Mistral (used for narrative style)
# Get key from: https://console.mistral.ai/
MISTRAL_API_KEY= your_mistral_key_here

# OpenAI (used for Whisper voice transcription)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY= your_openai_key_here

# OpenRouter (used for visual_interactive simulations)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY= your_openrouter_key_here

# DeepSeek (available but not currently routed)
# Get key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY= your_deepseek_key_here

# Napkin AI (used for diagram generation in visual slides)
# Get key from: https://app.napkin.ai/settings/api
# NOTE: Requires credits to generate diagrams
NAPKIN_API_KEY= your_napkin_key_here